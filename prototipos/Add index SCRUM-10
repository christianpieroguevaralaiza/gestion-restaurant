<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>QUIOSKO - Índice de Vistas HTML</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #1e1b4b 100%);
      min-height: 100vh;
      padding: 48px 24px;
      color: #f9fafb;
    }

    .container { max-width: 900px; margin: 0 auto; }

    header { text-align: center; margin-bottom: 48px; }
    header .logo { font-size: 56px; margin-bottom: 16px; }
    header h1 {
      font-size: 40px; font-weight: 900;
      background: linear-gradient(90deg, #fbbf24, #f59e0b);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      margin-bottom: 8px;
    }
    header p { color: #a5b4fc; font-size: 17px; }

    .section { margin-bottom: 40px; }
    .section-title {
      font-size: 13px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 2px;
      color: #818cf8; margin-bottom: 16px;
      padding-bottom: 8px;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .views-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 16px;
    }

    .view-card {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 12px;
      padding: 20px;
      text-decoration: none;
      color: #f9fafb;
      display: flex; flex-direction: column; gap: 8px;
      transition: all .2s ease;
      backdrop-filter: blur(8px);
    }
    .view-card:hover {
      background: rgba(255,255,255,0.13);
      border-color: #fbbf24;
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.25);
    }
    .view-card .icon { font-size: 32px; }
    .view-card .name {
      font-weight: 700; font-size: 16px; color: #fff;
    }
    .view-card .desc {
      font-size: 13px; color: #a5b4fc; line-height: 1.5;
    }
    .view-card .badge {
      display: inline-block; margin-top: 4px;
      background: rgba(251,191,36,0.15); color: #fbbf24;
      padding: 2px 10px; border-radius: 99px;
      font-size: 11px; font-weight: 700; width: fit-content;
      text-transform: uppercase; letter-spacing: 1px;
    }
    .badge.admin { background: rgba(79,70,229,0.2); color: #a5b4fc; }
  </style>
</head>
<body>
  <div class="container">

    <header>
      <div class="logo">🍽️</div>
      <h1>QUIOSKO</h1>
      <p>Índice de todas las vistas del sistema en HTML estático</p>
    </header>

    <!-- SECCIÓN: CLIENTE / QUIOSCO -->
    <div class="section">
      <p class="section-title">📱 Vista Cliente — Quiosco</p>
      <div class="views-grid">

        <a href="01_quiosco_menu.html" class="view-card">
          <span class="icon">🍔</span>
          <span class="name">Menú con Pedido</span>
          <span class="desc">Categorías, lista de productos y resumen del pedido con ítems añadidos.</span>
          <span class="badge">Quiosco</span>
        </a>

        <a href="02_quiosco_menu_vacio.html" class="view-card">
          <span class="icon">🛒</span>
          <span class="name">Menú — Carrito Vacío</span>
          <span class="desc">Pantalla de selección de productos con el carrito de pedido aún vacío.</span>
          <span class="badge">Quiosco</span>
        </a>

      </div>
    </div>

    <!-- SECCIÓN: PANTALLA DE ÓRDENES LISTAS -->
    <div class="section">
      <p class="section-title">📺 Pantalla de Órdenes Listas</p>
      <div class="views-grid">

        <a href="03_ordenes_listas.html" class="view-card">
          <span class="icon">✅</span>
          <span class="name">Órdenes Listas</span>
          <span class="desc">Pantalla pública que muestra las órdenes completadas y listas para recoger.</span>
          <span class="badge">Público</span>
        </a>

        <a href="11_ordenes_listas_vacias.html" class="view-card">
          <span class="icon">🕐</span>
          <span class="name">Órdenes Listas — Vacías</span>
          <span class="desc">Estado cuando no hay órdenes listas para mostrar al cliente.</span>
          <span class="badge">Público</span>
        </a>

      </div>
    </div>

    <!-- SECCIÓN: PANEL ADMINISTRACIÓN -->
    <div class="section">
      <p class="section-title">⚙️ Panel de Administración</p>
      <div class="views-grid">

        <a href="04_admin_ordenes.html" class="view-card">
          <span class="icon">📋</span>
          <span class="name">Admin — Órdenes</span>
          <span class="desc">Gestión de órdenes pendientes con botón para marcarlas como completadas.</span>
          <span class="badge admin">Admin</span>
        </a>

        <a href="10_admin_ordenes_vacias.html" class="view-card">
          <span class="icon">📭</span>
          <span class="name">Admin — Sin Órdenes</span>
          <span class="desc">Estado vacío cuando no hay órdenes pendientes en el panel de administración.</span>
          <span class="badge admin">Admin</span>
        </a>

        <a href="05_admin_productos.html" class="view-card">
          <span class="icon">📦</span>
          <span class="name">Admin — Productos</span>
          <span class="desc">Tabla de todos los productos con búsqueda, paginación y acceso a edición.</span>
          <span class="badge admin">Admin</span>
        </a>

        <a href="06_admin_nuevo_producto.html" class="view-card">
          <span class="icon">➕</span>
          <span class="name">Admin — Nuevo Producto</span>
          <span class="desc">Formulario para crear un nuevo producto: nombre, precio, categoría e imagen.</span>
          <span class="badge admin">Admin</span>
        </a>

        <a href="07_admin_editar_producto.html" class="view-card">
          <span class="icon">✏️</span>
          <span class="name">Admin — Editar Producto</span>
          <span class="desc">Formulario para editar un producto existente con datos precargados.</span>
          <span class="badge admin">Admin</span>
        </a>

        <a href="08_admin_buscar_productos.html" class="view-card">
          <span class="icon">🔍</span>
          <span class="name">Admin — Resultados Búsqueda</span>
          <span class="desc">Tabla filtrada con los resultados de búsqueda de productos por nombre.</span>
          <span class="badge admin">Admin</span>
        </a>

        <a href="09_admin_buscar_sin_resultados.html" class="view-card">
          <span class="icon">❌</span>
          <span class="name">Admin — Búsqueda Sin Resultados</span>
          <span class="desc">Estado vacío de la búsqueda cuando ningún producto coincide con el término.</span>
          <span class="badge admin">Admin</span>
        </a>

      </div>
    </div>

  </div>
</body>
</html>
